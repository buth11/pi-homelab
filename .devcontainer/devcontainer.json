{
  "name": "pi-homelab",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "latest",
      "minikube": "none"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "ms-azuretools.vscode-docker",
        "hashicorp.terraform",
        "github.vscode-github-actions",
        "redhat.vscode-yaml",
        "anthropic.claude-code"
      ]
    }
  },
  "forwardPorts": [8000, 5173],
  "portsAttributes": {
    "8000": { "label": "Dashboard Backend", "onAutoForward": "silent" },
    "5173": { "label": "Dashboard Frontend (dev)", "onAutoForward": "silent" }
  },
  "postCreateCommand": "pip install ansible && kubectl version --client && pip install -r /workspaces/pi-homelab/dashboard/backend/requirements.txt 2>/dev/null || true",
  "remoteEnv": {
    "KUBECONFIG": "/home/vscode/.kube/config",
    "PI_MASTER_IP": "192.168.50.10",
    "PI_WORKER1_IP": "192.168.50.11",
    "PI_WORKER2_IP": "192.168.50.12"
  }
}
